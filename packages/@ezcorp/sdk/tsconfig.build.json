{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": false,
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    // Explicit — under Bun's isolated linker (>=1.3.14) transitive @types/*
    // are symlinked into node_modules/.bun, which tsc's automatic @types
    // discovery misses from a workspace package. Pinning these (plus the
    // matching direct devDependencies) makes the build deterministic.
    "types": ["node", "bun"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/__tests__/**",
    "src/**/*.test.ts"
  ]
}
