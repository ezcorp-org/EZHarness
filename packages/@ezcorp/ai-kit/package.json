{
  "name": "@ezcorp/ai-kit",
  "version": "0.1.0",
  "type": "module",
  "description": "Integration kit that lets any LLM — external harness (Claude Code, Cursor, Zed, Windsurf) or in-EZCorp agent — drive the EZCorp backend: start chats, orchestrate agents/teams/tasks, fan out to multiple chats in parallel.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ezcorp-org/ezcorp.git",
    "directory": "packages/@ezcorp/ai-kit"
  },
  "keywords": [
    "ezcorp",
    "mcp",
    "claude-code",
    "ai-agent",
    "skill-library",
    "bun"
  ],
  "bin": {
    "ai-kit": "./src/cli/index.ts"
  },
  "files": [
    "dist",
    "src",
    "docs",
    "skills",
    "scripts",
    "llms.txt",
    "ezcorp.config.ts",
    "README.md"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "bun": "./src/client.ts",
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./mcp": {
      "bun": "./src/mcp/server.ts",
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    },
    "./extension": {
      "bun": "./ezcorp.config.ts",
      "types": "./dist/ezcorp.config.d.ts",
      "import": "./dist/ezcorp.config.js"
    }
  },
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "test:e2e": "bun test test/e2e",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text",
    "check-coverage": "bun run scripts/check-coverage.ts",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json",
    "verify": "bun run typecheck && bun run test:coverage && bun run check-coverage && bun test test/shape.test.ts",
    "mcp": "bun src/mcp/server.ts",
    "doctor": "bun src/cli/index.ts doctor",
    "install-target": "bun src/cli/index.ts install"
  },
  "peerDependencies": {
    "@ezcorp/sdk": "workspace:*"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  }
}
