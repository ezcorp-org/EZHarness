{
  "name": "ezcorp-ai-rocks",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": ["packages/@ezcorp/*"],
  "scripts": {
    "start": "bun run index.ts",
    "dev": "cd web && bun run dev",
    "build": "cd web && bun run build",
    "serve": "bun run index.ts serve",
    "preview": "cd web && bun run preview",
    "test": "bash scripts/test.sh",
    "test:file": "bun test",
    "test:e2e": "bash scripts/test-e2e.sh",
    "test:sdk": "bun test --cwd packages/@ezcorp/sdk",
    "test:coverage": "bash scripts/test-coverage.sh",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@ezcorp/ai-kit": "workspace:*",
    "@ezcorp/sdk": "workspace:*",
    "@huggingface/transformers": "^3.8.1",
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-ai": "^0.57.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.45.2",
    "file-type": "^22.0.1",
    "pdf-parse": "^2.4.5",
    "yaml": "^2.8.2"
  }
}
