{
  "name": "ezcorp-ai-rocks",
  "version": "1.3.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": ["packages/@ezcorp/*"],
  "scripts": {
    "postinstall": "bun run --cwd packages/@ezcorp/sdk build",
    "start": "bun run index.ts",
    "dev": "cd web && bun run dev",
    "build": "cd web && bun run build",
    "serve": "bun run index.ts serve",
    "preview": "cd web && bun run preview",
    "test": "bash scripts/test.sh",
    "test:file": "bun test",
    "test:e2e": "bash scripts/test-e2e.sh",
    "test:sdk": "bun test --cwd packages/@ezcorp/sdk",
    "test:coverage": "bash scripts/test-coverage.sh",
    "backfill:embeddings": "bun run scripts/backfill-embeddings.ts",
    "verify:backup": "bun run scripts/verify-backup-rollback.ts",
    "verify:edges": "bun run scripts/verify-circuit-breaker-edges.ts",
    "verify:docker": "bash scripts/verify-docker-image.sh",
    "verify:docker-rollback": "bash scripts/verify-docker-rollback.sh",
    "verify:docker-upgrade": "bash scripts/verify-docker-upgrade.sh",
    "verify:all": "bun run verify:backup && bun run verify:edges && bun run verify:docker && bun run verify:docker-rollback && bun run verify:docker-upgrade",
    "typecheck": "bash scripts/typecheck.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@ezcorp/ai-kit": "workspace:*",
    "@ezcorp/sdk": "workspace:*",
    "@huggingface/transformers": "^3.8.1",
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-ai": "^0.57.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "file-type": "^22.0.1",
    "pdf-parse": "^2.4.5",
    "yaml": "^2.8.2"
  }
}
