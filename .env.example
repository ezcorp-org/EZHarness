# ┌─────────────────────────────────────────────────────────────────────┐
# │ EZCorp environment template                                         │
# │                                                                     │
# │ Copy to `.env` and fill in the variables for your deployment mode.  │
# │   cp .env.example .env                                              │
# │                                                                     │
# │ Full reference: docs/production-guide.md                            │
# └─────────────────────────────────────────────────────────────────────┘

# ─── Self-hosted production (compose.prod.yml) ──────────────────────────
#
# Generate both with:
#   openssl rand -base64 32
#
# Stored credentials are encrypted with these values. Treat them as
# durable secrets: changing them on a live instance renders every stored
# credential unreadable. Store in a secret manager for real deployments.

EZCORP_ENCRYPTION_SECRET=
EZCORP_ENCRYPTION_SALT=

# Public-facing URL (used for OAuth callbacks and clickable deep-links).
# Leave empty for localhost; set to your reverse-proxy host otherwise.
# EZCORP_PUBLIC_URL=https://ezcorp.example.com

# JWT signing secret for sessions. If unset, auto-generated and persisted
# (encrypted) in the DB on first boot. Set explicitly to rotate via env
# or manage in a secret manager. Changing it invalidates all live sessions.
# EZCORP_JWT_SECRET=

# Update-check behaviour (in-app banner + /api/version).
# EZCORP_CHECK_UPDATES=true
# EZCORP_UPDATE_REPO=ezcorp-org/EZcorp

# ─── Feature flags ──────────────────────────────────────────────────────
#
# Autonomous `/goal` autopilot: the AI loops on its own until a goal
# condition is met (a cheap-model evaluator judges completion each turn).
# Shipped ON for every install. Set to 0/false/off/no to disable it — when
# off, `/goal` is hidden from the slash-command menu and the interceptor
# returns a "disabled" card.
EZCORP_GOAL_ENABLED=1

# ─── Secure preview port-watcher (Phase 2) ──────────────────────────────
#
# Auto-detection daemon for dev servers that start listening inside a
# conversation's sandbox. Detection only goes live once netns enumeration
# is wired (Phase 3); on the default fail-closed posture it is a no-op.
#
# Kill switch — set to 1 to never start the watcher daemon.
# EZCORP_DISABLE_PREVIEW_WATCHER=1
#
# Poll cadence in ms (default 2000, floored at 250). Lower = more
# responsive detection at the cost of more frequent /proc scans.
# EZCORP_PREVIEW_WATCHER_POLL_MS=2000

# External Postgres — only set if you've outgrown embedded PGlite.
# The app auto-detects this and skips PGlite + the local snapshot flow;
# backups become your DB provider's responsibility (pg_dump / WAL archive).
# DATABASE_URL=postgres://ezcorp:password@db.example.com:5432/ezcorp

# ─── Optional: credential seeding ───────────────────────────────────────
#
# Seed LLM provider keys at boot instead of entering them in the UI.
# Removed after first successful bootstrap. Prefer Settings > Provider Keys.
# SEED_ANTHROPIC_API_KEY=
# SEED_OPENAI_API_KEY=
# SEED_GOOGLE_API_KEY=

# ─── Optional: Google OAuth provider ────────────────────────────────────
#
# Create a Web Application OAuth client at
# https://console.cloud.google.com/apis/credentials and add
# http://localhost:1456/auth/callback as an authorized redirect URI.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Dev compose (docker-compose.yml — not for production) ──────────────
#
# Only used by the from-source dev stack, which runs an external pgvector
# container with live source mounts. Ignore these for self-hosted deploys.

POSTGRES_DB=ezcorp
POSTGRES_USER=ezcorp
POSTGRES_PASSWORD=ezcorp
POSTGRES_PORT=5432
EZCORP_PORT=3000
