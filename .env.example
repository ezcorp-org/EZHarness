# PostgreSQL
POSTGRES_DB=ezcorp
POSTGRES_USER=ezcorp
POSTGRES_PASSWORD=ezcorp
POSTGRES_PORT=5432

# App
EZCORP_PORT=3000

# Public origin of the EZCorp web UI — optional. Bundled ai-kit MCP
# uses it to build clickable deep-links in tool responses. Set this
# when users access the app on a different origin than the API
# (e.g. loopback API behind a Tailscale / HTTPS reverse proxy).
# EZCORP_PUBLIC_URL=https://ezcorp.example.com

# Secrets (generate your own for production)
EZCORP_JWT_SECRET=
EZCORP_ENCRYPTION_SALT=
EZCORP_ENCRYPTION_SECRET=

# Optional: LLM provider API keys (configured in-app, but can be seeded here)
# SEED_ANTHROPIC_API_KEY=
# SEED_OPENAI_API_KEY=
# SEED_GOOGLE_API_KEY=

# Google OAuth (required for "Sign in with Google" provider flow).
# Create a Web Application OAuth client at https://console.cloud.google.com/apis/credentials
# and add http://localhost:1456/auth/callback as an authorized redirect URI.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
