# ┌─────────────────────────────────────────────────────────────────────┐
# │ EZCorp production env template (compose.prod.yml)                   │
# │                                                                     │
# │ Copy to `.env.prod` and fill every REQUIRED block before deploying. │
# │   cp .env.prod.example .env.prod                                    │
# │   chmod 600 .env.prod                                               │
# │                                                                     │
# │ Full reference: docs/production-guide.md                            │
# │                                                                     │
# │ NEVER commit .env.prod. Real secrets only live on the deploy host.  │
# └─────────────────────────────────────────────────────────────────────┘

# ─── REQUIRED — deploy fails loudly if any of the four below are unset ──

# Encrypts OAuth tokens, provider API keys, and other credentials at rest.
# MUST be stable for the lifetime of the install — rotating it makes every
# previously-stored credential unreadable (users have to re-link providers).
# Do NOT let the app auto-generate this in prod; auto-gen on a fresh volume
# breaks decrypts on the next restart.
# Generate with:
#   openssl rand -base64 32
EZCORP_ENCRYPTION_SECRET=replace-with-openssl-rand-base64-32

# Paired with EZCORP_ENCRYPTION_SECRET for key derivation. Same stability
# rules apply — treat it as a peer secret, not a public salt.
# Generate with:
#   openssl rand -base64 16
EZCORP_ENCRYPTION_SALT=replace-with-openssl-rand-base64-16

# Signs session JWTs. Rotating it invalidates every live session (users
# get logged out). Set explicitly so you control rotation, instead of
# relying on the first-boot auto-generated fallback that lives in the DB.
# Generate with:
#   openssl rand -base64 32
EZCORP_JWT_SECRET=replace-with-openssl-rand-base64-32

# Public-facing URL of this deployment. Used as ORIGIN for SvelteKit's
# CSRF/origin checks and for clickable deep-links in tool responses.
# Without it, svelte-adapter-bun's get_origin() defaults the protocol
# to "https" which breaks login over plain HTTP. Include scheme; no
# trailing slash. Examples:
#   http://localhost:4000          (LAN / single-host)
#   https://ezcorp.example.com     (behind a TLS reverse proxy)
EZCORP_PUBLIC_URL=https://ezcorp.example.com

# ─── OPTIONAL — sensible defaults applied when omitted ──────────────────

# Force the `Secure` flag on session cookies. Leave at `false` for plain
# HTTP (LAN / dev-style self-host); flip to `true` ONLY when traffic
# reaches the app over HTTPS, otherwise browsers will silently drop the
# cookie and login appears broken. Default: false.
# FORCE_SECURE_COOKIES=false

# ─── Session lifetime tuning (all optional) ─────────────────────────────

# Cookie maxAge, JWT exp window, and the DB row's expiresAt all use this
# value. Bumping it lets browsers keep the cookie longer for return
# visitors. Default: 90 days.
# EZCORP_SESSION_LIFETIME_DAYS=90

# How old the inbound JWT must be before hooks.server.ts re-issues it
# inline (sliding refresh). Smaller = more frequent rotation, larger =
# less. Must be < EZCORP_SESSION_LIFETIME_DAYS. Default: 7 days.
# EZCORP_SESSION_REFRESH_AFTER_DAYS=7

# After a rotation, the previous token hash keeps validating for this
# many seconds so concurrent in-flight requests carrying the
# pre-rotation cookie aren't bounced as "session_revoked". Don't lower
# below ~30s unless you know your client never opens parallel requests.
# Default: 60.
# EZCORP_SESSION_PREVIOUS_TOKEN_GRACE_SECONDS=60

# Host port published by Docker. The container always listens on 3000
# internally; this only changes what's exposed on the host. Default: 4000.
# EZCORP_PORT_HOST=4000

# In-app update banner + GitHub Releases poll. Set to `false` for fully
# air-gapped installs. Default: true.
# EZCORP_CHECK_UPDATES=true

# Override the repo polled by the update check. Default: ezcorp-org/EZcorp.
# EZCORP_UPDATE_REPO=ezcorp-org/EZcorp

# Autonomous `/goal` autopilot — the AI loops on its own until a goal
# condition is met. Shipped ON for every install; omit to keep it enabled.
# Set to 0/false/off/no to disable (also hides `/goal` from the menu).
# Default: true.
# EZCORP_GOAL_ENABLED=1

# ─── Web search (SearXNG sidecar — all optional) ────────────────────────

# Where the bundled web-search extension finds SearXNG. The default
# points at the sidecar shipped in compose.prod.yml (service DNS over
# the compose bridge; no published port). Only set this to use a BYO
# SearXNG instance — it must enable `search.formats: [html, json]`, and
# a custom hostname needs the extension's network grant widened (see
# docs/deployment.md "Web search sidecar"). Keyless DuckDuckGo is the
# automatic fallback whenever SearXNG is unreachable.
# SEARXNG_BASE_URL=http://searxng:8080

# SearXNG instance secret. Defaults to a fixed internal-only value —
# acceptable because the sidecar is bridge-internal with no published
# port and nothing durable is encrypted with it. Set a real value if
# you ever publish the port or share the bridge with untrusted
# services. Generate with:
#   openssl rand -hex 32
# SEARXNG_SECRET=

# ─── Reverse proxy & security hardening (all optional) ──────────────────

# How many reverse-proxy hops sit in front of the app. Used to pick the
# real client IP out of the X-Forwarded-For chain for IP-keyed rate
# limiting. If you front the app with a TLS reverse proxy (Caddy, nginx,
# Traefik), set this to 1 (or the depth of your proxy chain). At the
# default of 0 the X-Forwarded-For header is IGNORED — unless your proxy
# also sets X-Real-IP, every client behind it collapses into a single
# rate-limit bucket, so e.g. the 5-per-minute login throttle locks out
# ALL users as soon as one person fat-fingers their password a few
# times. Default: 0 (direct connections, no proxy).
# TRUSTED_PROXY_COUNT=1

# Cross-origin allow-list for the API. Comma-separated list of exact
# origins (scheme://host[:port], no trailing slash), e.g.:
#   CORS_ALLOWED_ORIGINS=https://tools.example.com,https://admin.example.com
# Only origins on this list get Access-Control-Allow-Origin echoed back.
# Unset/empty means deny ALL cross-origin requests (the safe default —
# same-origin browser use is unaffected). A wildcard "*" entry is treated
# as deny, NOT allow-any: reflecting arbitrary origins on credentialed
# responses would leak authenticated data to any site. Default: unset.
# CORS_ALLOWED_ORIGINS=

# MCP extension sandbox policy. By default (off), when the host lacks
# full kernel sandboxing support (bwrap / network namespaces), MCP stdio
# extensions still launch — the sandbox degrades to weaker isolation and
# an audit-log entry records the downgrade. Set to "1" to fail closed:
# the server then REFUSES to spawn MCP stdio extensions when full kernel
# sandboxing is unavailable. Recommended: 1 for security-sensitive
# deployments. Default: off.
# EZCORP_MCP_REQUIRE_SANDBOX=1
